{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet publish:*)",
      "Bash(dydo agent claim:*)",
      "Bash(dydo agent --help:*)",
      "Bash(dydo whoami:*)",
      "Bash(dydo agent:*)",
      "Bash(dydo dispatch:*)",
      "Bash(dydo --help:*)",
      "Bash(dydo task create:*)",
      "Bash(dydo fix:*)",
      "Bash(dydo check:*)",
      "Bash(dydo inbox clear:*)",
      "Bash(dydo inbox show:*)",
      "Bash(dydo review:*)",
      "Bash(dydo inbox:*)",
      "Bash(dydo message:*)",
      "Bash(dydo msg:*)",
      "Bash(dydo wait:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|Bash|Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "dydo guard"
          }
        ]
      }
    ]
  }
}
