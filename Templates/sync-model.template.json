{
  "objects": [
    {
      "type": "Release",
      "dir": "project/releases",
      "notionTitle": "dydo Releases",
      "icon": "🏷️",
      "properties": {
        "title": { "type": "title" },
        "specRef": { "type": "rich_text" },
        "status": { "type": "select", "options": ["planned", "active", "shipped", "abandoned"],
          "colors": { "planned": "gray", "active": "blue", "shipped": "green", "abandoned": "brown" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "progress": { "type": "rollup", "viewOnly": true, "rollupRelation": "campaigns", "rollupProperty": "done", "rollupFunction": "percent_checked" },
        "start": { "type": "rollup", "viewOnly": true, "rollupRelation": "campaigns", "rollupProperty": "start-date", "rollupFunction": "earliest_date" },
        "end": { "type": "rollup", "viewOnly": true, "rollupRelation": "campaigns", "rollupProperty": "end-date", "rollupFunction": "latest_date" },
        "needs-human": { "type": "rollup", "viewOnly": true, "rollupRelation": "campaigns", "rollupProperty": "needs-human-count", "rollupFunction": "sum" },
        "attention-count": { "type": "rollup", "viewOnly": true, "rollupRelation": "campaigns", "rollupProperty": "attention", "rollupFunction": "checked" },
        "health": { "type": "formula", "viewOnly": true,
          "expression": "if(and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1)), \"Off Track\", if(or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2)))))), \"At Risk\", \"On Track\"))" },
        "attention": { "type": "formula", "viewOnly": true,
          "expression": "or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, prop(\"health\") != \"On Track\"))" }
      }
    },
    {
      "type": "Campaign",
      "dir": "project/campaigns",
      "notionTitle": "dydo Campaigns",
      "icon": "🚀",
      "properties": {
        "title": { "type": "title" },
        "goal": { "type": "rich_text" },
        "status": { "type": "select", "options": ["proposed", "active", "done", "abandoned"],
          "colors": { "proposed": "gray", "active": "blue", "done": "green", "abandoned": "brown" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "release": { "type": "relation", "to": "Release", "reverse": "campaigns" },
        "done": { "type": "formula", "viewOnly": true, "expression": "prop(\"status\") == \"done\"" },
        "progress": { "type": "rollup", "viewOnly": true, "rollupRelation": "sprints", "rollupProperty": "done", "rollupFunction": "percent_checked" },
        "start": { "type": "rollup", "viewOnly": true, "rollupRelation": "sprints", "rollupProperty": "start", "rollupFunction": "earliest_date" },
        "end": { "type": "rollup", "viewOnly": true, "rollupRelation": "sprints", "rollupProperty": "end", "rollupFunction": "latest_date" },
        "needs-human": { "type": "rollup", "viewOnly": true, "rollupRelation": "sprints", "rollupProperty": "needs-human-count", "rollupFunction": "sum" },
        "attention-count": { "type": "rollup", "viewOnly": true, "rollupRelation": "sprints", "rollupProperty": "attention", "rollupFunction": "checked" },
        "needs-human-count": { "type": "formula", "viewOnly": true, "expression": "prop(\"needs-human\")" },
        "start-date": { "type": "formula", "viewOnly": true, "expression": "prop(\"start\")" },
        "end-date": { "type": "formula", "viewOnly": true, "expression": "prop(\"end\")" },
        "health": { "type": "formula", "viewOnly": true,
          "expression": "if(and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1)), \"Off Track\", if(or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2))))), \"At Risk\", \"On Track\"))" },
        "attention": { "type": "formula", "viewOnly": true,
          "expression": "or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, prop(\"health\") != \"On Track\"))" }
      }
    },
    {
      "type": "Sprint",
      "dir": "project/sprints",
      "notionTitle": "dydo Sprints",
      "icon": "🏃",
      "properties": {
        "title": { "type": "title" },
        "seq": { "type": "number" },
        "status": { "type": "select", "options": ["planned", "active", "in-review", "done", "escalated"],
          "colors": { "planned": "gray", "active": "blue", "in-review": "yellow", "done": "green", "escalated": "red" } },
        "campaign": { "type": "relation", "to": "Campaign", "reverse": "sprints" },
        "start": { "type": "date" },
        "end": { "type": "date" },
        "gate-result": { "type": "select", "options": ["pass", "fail"],
          "colors": { "pass": "green", "fail": "red" } },
        "done": { "type": "formula", "viewOnly": true, "expression": "prop(\"status\") == \"done\"" },
        "progress": { "type": "rollup", "viewOnly": true, "rollupRelation": "tasks", "rollupProperty": "done", "rollupFunction": "percent_checked" },
        "needs-human": { "type": "rollup", "viewOnly": true, "rollupRelation": "tasks", "rollupProperty": "needs-human", "rollupFunction": "checked" },
        "needs-human-count": { "type": "formula", "viewOnly": true, "expression": "prop(\"needs-human\")" },
        "attention-count": { "type": "rollup", "viewOnly": true, "rollupRelation": "tasks", "rollupProperty": "attention", "rollupFunction": "checked" },
        "health": { "type": "formula", "viewOnly": true,
          "expression": "if(or(prop(\"gate-result\") == \"fail\", and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1))), \"Off Track\", if(or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2))))), \"At Risk\", \"On Track\"))" },
        "attention": { "type": "formula", "viewOnly": true,
          "expression": "or(prop(\"needs-human\") > 0, or(prop(\"status\") == \"escalated\", or(prop(\"attention-count\") > 0, prop(\"health\") != \"On Track\")))" }
      }
    },
    {
      "type": "SprintTask",
      "dir": "project/sprint-tasks",
      "notionTitle": "dydo Sprint Tasks",
      "icon": "📋",
      "properties": {
        "title": { "type": "title" },
        "status": { "type": "select", "options": ["backlog", "ready", "in-progress", "in-review", "blocked", "done"],
          "colors": { "backlog": "gray", "ready": "purple", "in-progress": "blue", "in-review": "yellow", "blocked": "red", "done": "green" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "sprint": { "type": "relation", "to": "Sprint", "reverse": "tasks" },
        "blocked-by": { "type": "relation", "to": "SprintTask", "reverse": "blocks" },
        "due": { "type": "date" },
        "work-type": { "type": "select", "options": ["feature", "bug", "chore", "spike", "docs"],
          "colors": { "feature": "blue", "bug": "red", "chore": "gray", "spike": "purple", "docs": "brown" } },
        "needs-human": { "type": "checkbox" },
        "last-activity": { "type": "date", "engineComputed": true },
        "done": { "type": "formula", "viewOnly": true, "expression": "prop(\"status\") == \"done\"" },
        "stale": { "type": "formula", "viewOnly": true,
          "expression": "and(or(prop(\"status\") == \"in-progress\", prop(\"status\") == \"in-review\"), and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3))" },
        "attention": { "type": "formula", "viewOnly": true,
          "expression": "or(prop(\"needs-human\"), or(prop(\"status\") == \"blocked\", prop(\"stale\")))" }
      }
    },
    {
      "type": "Issue",
      "dir": "project/issues",
      "notionTitle": "dydo Issues",
      "icon": "🐞",
      "properties": {
        "title": { "type": "title" },
        "status": { "type": "select", "options": ["triage", "open", "resolved"], "folders": { "resolved": "resolved" },
          "colors": { "triage": "gray", "open": "blue", "resolved": "green" } },
        "severity": { "type": "select", "options": ["critical", "high", "medium", "low"],
          "colors": { "critical": "red", "high": "orange", "medium": "yellow", "low": "gray" } },
        "area": { "type": "select", "options": ["backend", "general", "project", "reference", "understand"] },
        "work-type": { "type": "select", "options": ["feature", "bug", "chore", "spike", "docs"],
          "colors": { "feature": "blue", "bug": "red", "chore": "gray", "spike": "purple", "docs": "brown" } },
        "resolution": { "type": "select", "options": ["done", "wont-do", "duplicate", "cannot-reproduce", "superseded"],
          "colors": { "done": "green", "wont-do": "gray", "duplicate": "brown", "cannot-reproduce": "yellow", "superseded": "purple" } },
        "needs-human": { "type": "checkbox" },
        "fix-release": { "type": "relation", "to": "Release" },
        "last-activity": { "type": "date", "engineComputed": true },
        "stale": { "type": "formula", "viewOnly": true,
          "expression": "and(prop(\"status\") == \"open\", and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3))" },
        "attention": { "type": "formula", "viewOnly": true,
          "expression": "or(prop(\"needs-human\"), prop(\"stale\"))" }
      }
    }
  ]
}
