{
  "objects": [
    {
      "type": "Release",
      "dir": "project/releases",
      "notionTitle": "Releases",
      "icon": "🏷️",
      "properties": {
        "title": { "type": "title" },
        "specRef": { "type": "rich_text" },
        "status": { "type": "select", "options": ["planned", "active", "shipped", "abandoned"],
          "colors": { "planned": "gray", "active": "blue", "shipped": "green", "abandoned": "brown" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "progress": { "type": "rollup", "rollupRelation": "campaigns", "rollupProperty": "done", "rollupFunction": "percent_checked" },
        "start": { "type": "rollup", "rollupRelation": "campaigns", "rollupProperty": "start-date", "rollupFunction": "earliest_date" },
        "end": { "type": "rollup", "rollupRelation": "campaigns", "rollupProperty": "end-date", "rollupFunction": "latest_date" },
        "needs-human": { "type": "rollup", "rollupRelation": "campaigns", "rollupProperty": "needs-human-count", "rollupFunction": "sum" },
        "attention-count": { "type": "rollup", "rollupRelation": "campaigns", "rollupProperty": "attention", "rollupFunction": "checked", "hidden": true },
        "health": { "type": "formula",
          "expression": "if(and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1)), \"Off Track\", if(or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2)))))), \"At Risk\", \"On Track\"))" },
        "attention": { "type": "formula",
          "expression": "or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, if(and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1)), \"Off Track\", if(or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2)))))), \"At Risk\", \"On Track\")) != \"On Track\"))" }
      },
      "views": [
        { "name": "🗓️ Roadmap", "type": "timeline", "dateStart": "start", "dateEnd": "end" },
        { "name": "Active", "type": "table", "filter": { "property": "status", "operator": "equals", "value": "active" } },
        { "name": "All", "type": "table" }
      ]
    },
    {
      "type": "Campaign",
      "dir": "project/campaigns",
      "notionTitle": "Campaigns",
      "icon": "🚀",
      "properties": {
        "title": { "type": "title" },
        "goal": { "type": "rich_text" },
        "status": { "type": "select", "options": ["proposed", "active", "done", "abandoned"],
          "colors": { "proposed": "gray", "active": "blue", "done": "green", "abandoned": "brown" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "release": { "type": "relation", "to": "Release", "reverse": "campaigns" },
        "done": { "type": "formula", "expression": "prop(\"status\") == \"done\"" },
        "progress": { "type": "rollup", "rollupRelation": "sprints", "rollupProperty": "done", "rollupFunction": "percent_checked" },
        "start": { "type": "rollup", "rollupRelation": "sprints", "rollupProperty": "start", "rollupFunction": "earliest_date" },
        "end": { "type": "rollup", "rollupRelation": "sprints", "rollupProperty": "end", "rollupFunction": "latest_date" },
        "needs-human": { "type": "rollup", "rollupRelation": "sprints", "rollupProperty": "needs-human-count", "rollupFunction": "sum" },
        "attention-count": { "type": "rollup", "rollupRelation": "sprints", "rollupProperty": "attention", "rollupFunction": "checked", "hidden": true },
        "needs-human-count": { "type": "formula", "expression": "prop(\"needs-human\")", "hidden": true },
        "start-date": { "type": "formula", "expression": "prop(\"start\")", "hidden": true },
        "end-date": { "type": "formula", "expression": "prop(\"end\")", "hidden": true },
        "health": { "type": "formula",
          "expression": "if(and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1)), \"Off Track\", if(or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2))))), \"At Risk\", \"On Track\"))" },
        "attention": { "type": "formula",
          "expression": "or(prop(\"needs-human\") > 0, or(prop(\"attention-count\") > 0, if(and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1)), \"Off Track\", if(or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2))))), \"At Risk\", \"On Track\")) != \"On Track\"))" }
      },
      "views": [
        { "name": "🗓️ Roadmap", "type": "timeline", "dateStart": "start", "dateEnd": "end" },
        { "name": "🚨 Needs Attention", "type": "table", "filter": { "property": "needs-human", "operator": "equals", "value": "true" } },
        { "name": "Active Bets", "type": "table", "filter": { "property": "status", "operator": "equals", "value": "active" } },
        { "name": "Board", "type": "board", "groupBy": "status" },
        { "name": "All", "type": "table" }
      ]
    },
    {
      "type": "Sprint",
      "dir": "project/sprints",
      "notionTitle": "Sprints",
      "icon": "🏃",
      "properties": {
        "title": { "type": "title" },
        "seq": { "type": "number" },
        "status": { "type": "select", "options": ["planned", "active", "in-review", "done", "escalated"],
          "colors": { "planned": "gray", "active": "blue", "in-review": "yellow", "done": "green", "escalated": "red" } },
        "campaign": { "type": "relation", "to": "Campaign", "reverse": "sprints" },
        "start": { "type": "date" },
        "end": { "type": "date" },
        "gate-result": { "type": "rich_text" },
        "done": { "type": "formula", "expression": "prop(\"status\") == \"done\"" },
        "progress": { "type": "rollup", "rollupRelation": "tasks", "rollupProperty": "done", "rollupFunction": "percent_checked" },
        "needs-human": { "type": "rollup", "rollupRelation": "tasks", "rollupProperty": "needs-human", "rollupFunction": "checked" },
        "needs-human-count": { "type": "formula", "expression": "prop(\"needs-human\")", "hidden": true },
        "attention-count": { "type": "rollup", "rollupRelation": "tasks", "rollupProperty": "attention", "rollupFunction": "checked", "hidden": true },
        "health": { "type": "formula",
          "expression": "if(or(test(prop(\"gate-result\"), \"(?i)fail\"), and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1))), \"Off Track\", if(or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2))))), \"At Risk\", \"On Track\"))" },
        "attention": { "type": "formula",
          "expression": "or(prop(\"needs-human\") > 0, or(prop(\"status\") == \"escalated\", or(prop(\"attention-count\") > 0, if(or(test(prop(\"gate-result\"), \"(?i)fail\"), and(not empty(prop(\"end\")), and(dateBetween(now(), prop(\"end\"), \"days\") > 0, prop(\"progress\") < 1))), \"Off Track\", if(or(prop(\"attention-count\") > 0, and(not empty(prop(\"start\")), and(not empty(prop(\"end\")), and(dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0, and(dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\") > 0.6, prop(\"progress\") < (dateBetween(now(), prop(\"start\"), \"days\") / dateBetween(prop(\"end\"), prop(\"start\"), \"days\")) / 2))))), \"At Risk\", \"On Track\")) != \"On Track\")))" }
      },
      "views": [
        { "name": "Board", "type": "board", "groupBy": "status" },
        { "name": "🚨 Needs Attention", "type": "table", "filter": { "property": "needs-human", "operator": "equals", "value": "true" } },
        { "name": "Active", "type": "table", "filter": { "property": "status", "operator": "equals", "value": "active" } },
        { "name": "All", "type": "table" }
      ]
    },
    {
      "type": "Slice",
      "dir": "project/slices",
      "notionTitle": "Slices",
      "icon": "📋",
      "properties": {
        "title": { "type": "title" },
        "status": { "type": "select", "options": ["backlog", "ready", "in-progress", "in-review", "blocked", "done"],
          "colors": { "backlog": "gray", "ready": "purple", "in-progress": "blue", "in-review": "yellow", "blocked": "red", "done": "green" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "sprint": { "type": "relation", "to": "Sprint", "reverse": "tasks" },
        "blocked-by": { "type": "relation", "to": "Slice", "reverse": "blocks" },
        "due": { "type": "date" },
        "work-type": { "type": "select", "options": ["feature", "bug", "chore", "spike", "docs"],
          "colors": { "feature": "blue", "bug": "red", "chore": "gray", "spike": "purple", "docs": "brown" } },
        "needs-human": { "type": "checkbox" },
        "last-activity": { "type": "date", "engineComputed": true, "hidden": true },
        "done": { "type": "formula", "expression": "prop(\"status\") == \"done\"" },
        "stale": { "type": "formula",
          "expression": "and(or(prop(\"status\") == \"in-progress\", prop(\"status\") == \"in-review\"), and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3))" },
        "attention": { "type": "formula",
          "expression": "or(prop(\"needs-human\"), or(prop(\"status\") == \"blocked\", and(or(prop(\"status\") == \"in-progress\", prop(\"status\") == \"in-review\"), and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3))))" }
      },
      "views": [
        { "name": "Board", "type": "board", "groupBy": "status" },
        { "name": "🚨 Needs Attention", "type": "table", "filter": { "property": "needs-human", "operator": "equals", "value": "true" } },
        { "name": "Due Soon", "type": "table", "filter": { "property": "status", "operator": "does_not_equal", "value": "done" }, "sort": [{ "property": "due", "direction": "ascending" }] },
        { "name": "Blocked", "type": "table", "filter": { "property": "status", "operator": "equals", "value": "blocked" } },
        { "name": "All", "type": "table" }
      ]
    },
    {
      "type": "Issue",
      "dir": "project/issues",
      "notionTitle": "Issues",
      "icon": "🪲",
      "properties": {
        "title": { "type": "title" },
        "status": { "type": "select", "options": ["triage", "open", "resolved"], "folders": { "resolved": "resolved" },
          "colors": { "triage": "gray", "open": "blue", "resolved": "green" } },
        "severity": { "type": "select", "options": ["critical", "high", "medium", "low"],
          "colors": { "critical": "red", "high": "orange", "medium": "yellow", "low": "gray" } },
        "area": { "type": "select", "options": ["backend", "general", "project", "reference", "understand"] },
        "work-type": { "type": "select", "options": ["feature", "bug", "chore", "spike", "docs"],
          "colors": { "feature": "blue", "bug": "red", "chore": "gray", "spike": "purple", "docs": "brown" } },
        "resolution": { "type": "select", "options": ["done", "wont-do", "duplicate", "cannot-reproduce", "superseded"],
          "colors": { "done": "green", "wont-do": "gray", "duplicate": "brown", "cannot-reproduce": "yellow", "superseded": "purple" } },
        "needs-human": { "type": "checkbox" },
        "fix-release": { "type": "relation", "to": "Release" },
        "last-activity": { "type": "date", "engineComputed": true, "hidden": true },
        "stale": { "type": "formula",
          "expression": "and(prop(\"status\") == \"open\", and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3))" },
        "attention": { "type": "formula",
          "expression": "or(prop(\"needs-human\"), and(prop(\"status\") == \"open\", and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3)))" }
      },
      "views": [
        { "name": "Open", "type": "table", "filter": { "property": "status", "operator": "does_not_equal", "value": "resolved" }, "sort": [{ "property": "severity", "direction": "ascending" }] },
        { "name": "🚨 Needs Attention", "type": "table", "filter": { "property": "needs-human", "operator": "equals", "value": "true" }, "sort": [{ "property": "severity", "direction": "ascending" }] },
        { "name": "Triage", "type": "table", "filter": { "property": "status", "operator": "equals", "value": "triage" } },
        { "name": "By Area", "type": "board", "groupBy": "area" },
        { "name": "All", "type": "table" }
      ]
    },
    {
      "type": "Task",
      "dir": "project/tasks",
      "notionTitle": "Tasks",
      "icon": "✅",
      "properties": {
        "title": { "type": "title" },
        "status": { "type": "select", "options": ["backlog", "in-progress", "in-review", "done"], "folders": { "backlog": "backlog" },
          "colors": { "backlog": "gray", "in-progress": "blue", "in-review": "yellow", "done": "green" } },
        "priority": { "type": "select", "options": ["Urgent", "High", "Normal", "Low"],
          "colors": { "Urgent": "red", "High": "orange", "Normal": "yellow", "Low": "gray" } },
        "work-type": { "type": "select", "options": ["feature", "bug", "chore", "spike", "docs"],
          "colors": { "feature": "blue", "bug": "red", "chore": "gray", "spike": "purple", "docs": "brown" } },
        "needs-human": { "type": "checkbox" },
        "last-activity": { "type": "date", "engineComputed": true, "hidden": true },
        "done": { "type": "formula", "expression": "prop(\"status\") == \"done\"" },
        "stale": { "type": "formula",
          "expression": "and(or(prop(\"status\") == \"in-progress\", prop(\"status\") == \"in-review\"), and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3))" },
        "attention": { "type": "formula",
          "expression": "or(prop(\"needs-human\"), and(or(prop(\"status\") == \"in-progress\", prop(\"status\") == \"in-review\"), and(not empty(prop(\"last-activity\")), dateBetween(now(), prop(\"last-activity\"), \"days\") > 3)))" }
      },
      "views": [
        { "name": "Board", "type": "board", "groupBy": "status" },
        { "name": "🚨 Needs Attention", "type": "table", "filter": { "property": "needs-human", "operator": "equals", "value": "true" } },
        { "name": "Backlog", "type": "table", "filter": { "property": "status", "operator": "equals", "value": "backlog" } },
        { "name": "All", "type": "table" }
      ]
    },
    {
      "type": "FutureFeature",
      "dir": "project/future-features",
      "notionTitle": "Future Features",
      "icon": "💡",
      "properties": {
        "title": { "type": "title" },
        "status": { "type": "select", "options": ["raw", "shaping", "promoted", "dropped"],
          "colors": { "raw": "gray", "shaping": "blue", "promoted": "green", "dropped": "brown" } },
        "area": { "type": "select", "options": ["backend", "general", "project", "reference", "understand"] }
      },
      "views": [
        { "name": "Board", "type": "board", "groupBy": "status" },
        { "name": "By Area", "type": "board", "groupBy": "area" },
        { "name": "All", "type": "table" }
      ]
    }
  ]
}
