{
  "version": 1,
  "name": null,
  "structure": {
    "root": "dydo",
    "tasks": "project/tasks",
    "issues": "project/issues"
  },
  "paths": {
    "source": [
      "Commands/**",
      "Sync/**",
      "Services/**",
      "Models/**",
      "Rules/**",
      "Utils/**",
      "Serialization/**",
      "Program.cs",
      "Templates/**"
    ],
    "tests": [
      "DynaDocs.Tests/**"
    ],
    "pathSets": null
  },
  "integrations": {
    "claude": true
  },
  "notion": {
    "parentPageId": null,
    "tokenStorage": "local"
  },
  "models": {
    "tiers": {
      "anthropic": {
        "strong": "claude-fable-5",
        "standard": "claude-opus-4-8",
        "light": "claude-haiku-4-5"
      },
      "openai": {
        "strong": "gpt-5.6-sol",
        "standard": "gpt-5.6-terra",
        "light": "gpt-5.6-luna"
      }
    },
    "roles": {
      "code-writer": "standard",
      "test-writer": "standard",
      "docs-writer": "standard",
      "reviewer": "strong",
      "sprint-auditor": "strong",
      "inquisitor": "strong",
      "judge": "strong",
      "planner": "strong"
    },
    "efforts": {},
    "fallback": null
  },
  "scanExclude": [
    "_system/.local/",
    "_system/audit/"
  ],
  "nudges": [
    {
      "pattern": "(?:^|[;\u0026|]\\s*)npx\\s\u002B(?:(?:-\\w\u002B|--[\\w-]\u002B(?:\\s\u002B\\S\u002B)?)\\s\u002B)*dydo\\b(.*)",
      "message": "Don\u0027t use npx to run dydo \u2014 it\u0027s already on your PATH. Just use: dydo $1",
      "severity": "block"
    },
    {
      "pattern": "(?:^|[;\u0026|]\\s*)dotnet\\s\u002B(?:tool\\s\u002Brun\\s\u002B)?dydo\\b(.*)",
      "message": "Don\u0027t use dotnet to run dydo \u2014 it\u0027s already on your PATH. Just use: dydo $1",
      "severity": "block"
    },
    {
      "pattern": "(?:^|[;\u0026|]\\s*)dotnet\\s\u002Brun\\b(?:\\s\u002B(?:-\\w\u002B|--[\\w-]\u002B(?:[=\\s]\\S\u002B)?))*\\s\u002B--\\s\u002B((?:guard|task|review|template|init|check|fix|index|graph|completions|complete|version|help|validate|issue|inquisition|watchdog)\\b.*)",
      "message": "Don\u0027t use dotnet run to invoke dydo \u2014 it\u0027s already on your PATH. Just use: dydo $1",
      "severity": "block"
    },
    {
      "pattern": "(?:^|[;\u0026|]\\s*)(bash|sh|zsh|cmd|powershell|pwsh)\\s\u002B(?:(?:-\\w\u002B|--[\\w-]\u002B(?:\\s\u002B\\S\u002B)?)\\s\u002B)*(?:[\u0022\u0027])?dydo(?=[\\s\u0022\u0027]|$)(.*?)(?:[\u0022\u0027])?$",
      "message": "Don\u0027t use \u0027$1\u0027 to run dydo \u2014 it\u0027s already on your PATH. Just use: dydo $2",
      "severity": "block"
    },
    {
      "pattern": "(?:^|[;\u0026|]\\s*)(python3?|py)\\s\u002B(?:(?:-\\w\u002B|--[\\w-]\u002B(?:\\s\u002B\\S\u002B)?)\\s\u002B)*(?:[\u0022\u0027])?dydo(?=[\\s\u0022\u0027]|$)(.*?)(?:[\u0022\u0027])?$",
      "message": "Don\u0027t use \u0027$1\u0027 to run dydo \u2014 it\u0027s already on your PATH. Just use: dydo $2",
      "severity": "block"
    },
    {
      "pattern": "(?:^|[;\u0026|]\\s*)dotnet\\s\u002Btest\\b(.*)",
      "message": "Use the worktree-isolated test runner instead: python DynaDocs.Tests/coverage/run_tests.py $1\nThis avoids DLL lock contention when multiple agents run tests concurrently.",
      "severity": "warn"
    },
    {
      "pattern": "\\buntil\\s\u002B\\[",
      "message": "Open-ended Bash poll-loop detected. Prefer a bounded for i in {1..30}; do ...; sleep 1; done, or \u0060gh run watch\u0060. Open-ended polls have caused agent crashes (issue 0177).",
      "severity": "warn"
    },
    {
      "pattern": "{source}|{tests}",
      "message": "Tier-1 agents are managers (Decision 026): delegate implementation to a run-sprint workflow unless this change is trivial. Rule of thumb: if it needs a reviewer, it needs a workflow.",
      "severity": "notice",
      "tools": [
        "Edit",
        "Write",
        "NotebookEdit"
      ]
    }
  ],
  "frameworkHashes": {
    "reference/about-dynadocs.md": "20b793ac842060987f33f3fbf02d67b698dd5e3352a27e60e872af35d3c7b0d9",
    "reference/dydo-commands.md": "cb862bd8b07ff2686d205887b74236570c1a1bcb6015bb42d8d3557f779da039",
    "reference/writing-docs.md": "80c23dd9d7d84803dcca60aa9195a4ca0fa86a408220babdba3df3fe5a30bc92",
    "guides/how-to-use-docs.md": "74a4c439dc181ef2edfe4db227ccd537e945bf33f8761dc68b86e1c461a2633f",
    "_assets/dydo-diagram.svg": "d93720f85fc71f4a75798a364d783c18e70c94fd349fa462919e10cbc9c223b9"
  }
}