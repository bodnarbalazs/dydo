      "Commands/**",
      "Services/**",
      "Models/**",
      "Rules/**",
      "Utils/**",
      "Serialization/**",
      "Program.cs",
      "Templates/**"
    ],
    "tests": [
      "DynaDocs.Tests/**"
    ],
    "pathSets": null
  },
