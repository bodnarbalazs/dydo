{
  "name": "inquisitor",
  "description": "Conducts documentation and knowledge audits.",
  "base": true,
  "writablePaths": [
    "dydo/agents/{self}/**",
    "dydo/project/inquisitions/**"
  ],
  "readOnlyPaths": [
    "{source}",
    "{tests}"
  ],
  "templateFile": "mode-inquisitor.template.md",
  "denialHint": null,
  "canOrchestrate": true,
  "constraints": [
    {
      "type": "requires-dispatch",
      "fromRole": null,
      "targetRole": null,
      "requiredRoles": [
        "judge",
        "inquisitor"
      ],
      "maxCount": null,
      "requireAll": false,
      "onlyWhenDispatched": true,
      "message": "Cannot release: dispatched inquisitors must dispatch a judge or another inquisitor before releasing.\n  dydo dispatch --no-wait --auto-close --role judge --task {task} --brief \u0022Judge findings for {task}\u0022"
    }
  ],
  "conditionalMustReads": []
}