{
  "name": "judge",
  "description": "Evaluates inquisition reports and arbitrates disputes.",
  "base": true,
  "writablePaths": [
    "dydo/agents/{self}/**",
    "dydo/project/issues/**"
  ],
  "readOnlyPaths": [
    "{source}",
    "{tests}"
  ],
  "templateFile": "mode-judge.template.md",
  "denialHint": null,
  "canOrchestrate": true,
  "constraints": [
    {
      "type": "panel-limit",
      "fromRole": null,
      "targetRole": null,
      "requiredRoles": null,
      "maxCount": 3,
      "onlyWhenDispatched": false,
      "message": "Maximum 3 judges already active on task \u0027{task}\u0027. Escalate to the human."
    }
  ]
}