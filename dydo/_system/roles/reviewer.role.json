{
  "name": "reviewer",
  "description": "Reviews code changes for quality and correctness.",
  "base": true,
  "writablePaths": [
    "dydo/agents/{self}/**"
  ],
  "readOnlyPaths": [
    "**"
  ],
  "templateFile": "mode-reviewer.template.md",
  "denialHint": "Reviewer role can only edit own workspace.",
  "canOrchestrate": false,
  "constraints": [
    {
      "type": "role-transition",
      "fromRole": "code-writer",
      "targetRole": null,
      "requiredRoles": null,
      "maxCount": null,
      "requireAll": true,
      "onlyWhenDispatched": false,
      "message": "Agent {agent} was code-writer on task \u0027{task}\u0027 and cannot be reviewer on the same task. Dispatch to a different agent for review."
    },
    {
      "type": "dispatch-restriction",
      "fromRole": null,
      "targetRole": "code-writer",
      "requiredRoles": [
        "code-writer",
        "inquisitor"
      ],
      "maxCount": null,
      "requireAll": true,
      "onlyWhenDispatched": true,
      "message": "Reviewers can only dispatch a code-writer when dispatched by a code-writer or inquisitor. Report findings back to your dispatcher instead.\n  dydo msg --to {dispatcher} --subject {task} --body \u0022Review findings: ...\u0022"
    }
  ],
  "conditionalMustReads": [
    {
      "when": {
        "markerExists": null,
        "taskNameMatches": "*-merge",
        "dispatchedByRole": null
      },
      "path": "dydo/guides/how-to-review-worktree-merges.md"
    },
    {
      "when": null,
      "path": "dydo/project/tasks/{task}.md"
    },
    {
      "when": {
        "markerExists": null,
        "taskNameMatches": null,
        "dispatchedByRole": "docs-writer"
      },
      "path": "dydo/reference/writing-docs.md"
    }
  ]
}