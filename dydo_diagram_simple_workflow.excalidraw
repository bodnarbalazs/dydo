      "versionNonce": 526541810,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774649340976,
      "link": null,
      "locked": false,
      "text": "Adele:\nThe card has display: inline-block\nfrom the .card base class —\nmargin: 0 auto only works on block-\nlevel elements.\n  Two options: change the card to\ndisplay: block, or use text-align:\ncenter on the parent. I'd go with\ndisplay: block\n  since the card isn't inline\ncontent.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Adele:\nThe card has display: inline-block from the .card base class — margin: 0 auto only works on block-level elements.\n  Two options: change the card to display: block, or use text-align: center on the parent. I'd go with display: block\n  since the card isn't inline content.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
