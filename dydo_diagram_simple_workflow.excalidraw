      "seed": 976743492,
      "version": 642,
      "versionNonce": 1483691054,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774531315802,
      "link": null,
      "locked": false,
      "text": "The agent checks inside it's inbox folder\nfor tasks. It might have been dispatched\nas a code-reviewer, code-writer, tester or\nwith some other role by another agent.\nIt reads the attached details, gathers\nmore context, then starts executing it's task.\nWhen complete it might message back the\nsender with the results.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The agent checks inside it's inbox folder\nfor tasks. It might have been dispatched\nas a code-reviewer, code-writer, tester or\nwith some other role by another agent.\nIt reads the attached details, gathers\nmore context, then starts executing it's task.\nWhen complete it might message back the\nsender with the results.",
      "autoResize": true,
      "lineHeight": 1.25
    },
