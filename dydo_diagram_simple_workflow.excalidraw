      "link": null,
      "locked": false,
      "text": "The agent claims it's identity by running\n'dydo claim <agent_name>'\nbased on it's prompt it decides what is the desired workflow\nand which mode file it should read next as part of it's onboarding. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The agent claims it's identity by running\n'dydo claim <agent_name>'\nbased on it's prompt it decides what is the desired workflow\nand which mode file it should read next as part of it's onboarding. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
