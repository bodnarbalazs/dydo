      "isDeleted": false,
      "boundElements": [],
      "updated": 1774649340976,
      "link": null,
      "locked": false,
      "text": "Adele:\nThis is a simple change, do you\nwant me to switch to roles and fix\nit myself or should we dispatch a\ncode-writer?\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Adele:\nThis is a simple change, do you want me to switch to roles and fix it myself or should we dispatch a code-writer?\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
